// ============================================================================
// PRIVACY — Decentralised routing privacy tiers
// ============================================================================

model PrivacyPolicy {
  id              String           @id @default(cuid())
  userId          String
  name            String           // "Default", "HIPAA Compliant", "Public Only"
  isDefault       Boolean          @default(false)
  tier            RoutingPrivacyTier @default(TRANSPORT_ONLY)
  allowedRegions  String[]         // ISO 3166-1 alpha-2 codes (empty = any)
  requireTEE      Boolean          @default(false)
  minFragments    Int              @default(3)
  maxFragments    Int              @default(5)
  piiStripping    Boolean          @default(false)
  canaryInjection Boolean          @default(true)
  maxLatencyMs    Int?             // latency budget (null = no limit)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("privacy_policies")
}

model CanaryEvent {
  id           String   @id @default(cuid())
  canaryId     String   @unique
  token        String
  userId       String
  nodeId       String?
  fragmentId   String?
  status       CanaryStatus @default(ACTIVE)
  injectedAt   DateTime @default(now())
  detectedAt   DateTime?
  detectedIn   String?  // where the canary was found (URL, API endpoint, etc.)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([token])
  @@map("canary_events")
}

enum RoutingPrivacyTier {
  TRANSPORT_ONLY    // Tier 0: mTLS only, node sees plaintext
  BLIND_ROUTING     // Tier 1: prompt fragmented across nodes
  TEE_PREFERRED     // Tier 1.5: TEE nodes when available, fallback to fragmentation
  CONFIDENTIAL      // Tier 2: TEE required, cryptographic attestation
}

enum CanaryStatus {
  ACTIVE
  TRIGGERED
  EXPIRED
}

// ============================================================================
// COMPUTE INTELLIGENCE & SETTLEMENT LANES (Stream U)
// ============================================================================

model ComputeClassification {
  id                    String   @id @default(cuid())
  targetType            String                              // 'provider' | 'node'
  targetId              String                              // AIProvider enum value or NodeOperator ID
  model                 String                              // specific model being classified
  inferenceType         ComputeInferenceType
  qualityTier           ComputeQualityTier
  latencyClass          ComputeLatencyClass
  privacyClass          ComputePrivacyClass
  availabilityClass     ComputeAvailabilityClass
  hardwareClass         ComputeHardwareClass
  regions               String[]                            // ISO 3166-1 alpha-2

  // Measured metrics from verification probes
  measuredLatencyMs     Int?
  measuredThroughputTps Decimal?   @db.Decimal(10, 2)       // tokens/second
  measuredAccuracy      Decimal?   @db.Decimal(5, 4)        // 0.0000–1.0000

  // Verification status
  verificationScore     Int        @default(0)              // 0–100 composite
  lastVerifiedAt        DateTime?
  verificationTTLHours  Int        @default(24)

  // Cryptographic attestation
  signature             String?                             // HMAC-SHA256 hex
  signedAt              DateTime?
  signerKeyId           String?

  // Settlement lane assignment
  settlementLane        ComputeSettlementLane @default(DEFERRED)
  settlementDelayHours  Int        @default(168)            // 7 days default
  escrowRequired        Boolean    @default(false)
  disputeWindowHours    Int        @default(168)

  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Relations
  verificationResults   ComputeVerificationResult[]

  @@unique([targetType, targetId, model])
  @@index([settlementLane])
  @@index([qualityTier, latencyClass])
  @@index([targetId])
  @@map("compute_classifications")
}

model ComputeVerificationResult {
  id                String                  @id @default(cuid())
  classificationId  String
  method            ComputeVerificationMethod
  outcome           ComputeVerificationOutcome
  details           Json                    @default("{}")   // method-specific evidence
  latencyMs         Int
  executedAt        DateTime                @default(now())

  classification    ComputeClassification   @relation(fields: [classificationId], references: [id], onDelete: Cascade)

  @@index([classificationId, executedAt])
  @@map("compute_verification_results")
}

model ComputeSettlementRecord {
  id                String                  @id @default(cuid())
  requestId         String?                                  // ProxyRequest linkage
  lane              ComputeSettlementLane
  amountUsd         Decimal                 @db.Decimal(12, 6)
  payeeType         String                                   // 'provider' | 'node'
  payeeId           String
  status            ComputeSettlementStatus @default(PENDING)
  settledAt         DateTime?
  disputeReason     String?
  escrowReleaseAt   DateTime?
  createdAt         DateTime                @default(now())

  @@index([payeeId, status])
  @@index([status, escrowReleaseAt])
  @@index([requestId])
  @@map("compute_settlement_records")
}

model TrustSnapshot {
  id              String              @id @default(cuid())
  entityId        String
  entityType      String                                     // 'provider' | 'node'
  trustScore      Int                                        // 0–100
  uptimeScore     Decimal             @db.Decimal(5, 2)      // 0–25
  accuracyScore   Decimal             @db.Decimal(5, 2)      // 0–25
  volumeScore     Decimal             @db.Decimal(5, 2)      // 0–25
  disputeScore    Decimal             @db.Decimal(5, 2)      // 0–25
  currentLane     ComputeSettlementLane
  snapshotAt      DateTime            @default(now())

  @@index([entityId, snapshotAt])
  @@map("trust_snapshots")
}

model PlatformMetrics {
  id                    String   @id @default(cuid())
  totalSettledUsd       Decimal  @db.Decimal(14, 2)
  averageDisputeRate    Decimal  @db.Decimal(8, 6)           // 0.000000–1.000000
  activeNodes           Int
  activeProviders       Int
  instantLaneThreshold  Int      @default(80)                // trust score needed for instant
  deferredDelayDays     Int      @default(30)
  verificationTTLHours  Int      @default(24)
  maturityLevel         String   @default("Early")
  computedAt            DateTime @default(now())

  @@index([computedAt])
  @@map("platform_metrics")
}

