// InferLane — Full SaaS Database Schema
// The financial dashboard for AI-powered teams

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// AUTH — NextAuth.js required models
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Partner attribution (which integration partner referred this user)
  partnerId     String?

  // Relations
  accounts          Account[]
  sessions          Session[]
  subscription      Subscription?
  providerConnections ProviderConnection[]
  spendSnapshots    SpendSnapshot[]
  alerts            Alert[]
  affiliateClicks   AffiliateClick[]
  teams             TeamMember[]
  apiKeys           ApiKey[]
  recommendations   ProviderRecommendation[]
  partner           Partner?  @relation("PartnerReferrals", fields: [partnerId], references: [id], onDelete: SetNull)
  creditBalance     CreditBalance?
  creditTransactions CreditTransaction[]
  creditOffers      CreditOffer[]
  poolDelegations   PoolDelegation[]
  privacyPolicies    PrivacyPolicy[]
  canaryEvents       CanaryEvent[]
  creditConsumptions CreditConsumption[]
  nodeOperator       NodeOperator?
  tradingApiKeys     TradingApiKey[]
  computeOrders      ComputeOrder[]
  futuresCreated     ComputeFuture[]   @relation("FutureCreator")
  notificationPrefs  NotificationPreferences?
  deletedAt          DateTime?
  scheduledPrompts   ScheduledPrompt[]
  promptTemplates    PromptTemplate[]
  fleets             Fleet[]
  fleetSessions      FleetSession[]
  kycSessions        KycSession[]       @relation("UserKycSessions")

  @@map("users")
}

// ---------------------------------------------------------------------------
// Notification Preferences (Stream Y3)
// ---------------------------------------------------------------------------

model NotificationPreferences {
  id              String   @id @default(cuid())
  userId          String   @unique
  weeklyDigest    Boolean  @default(true)
  alertEmails     Boolean  @default(true)
  tradeNotifs     Boolean  @default(true)
  payoutNotifs    Boolean  @default(true)
  marketingEmails Boolean  @default(false)

  // Channel connection credentials — users configure these in
  // /dashboard/settings → Notifications. All nullable; channels
  // without credentials are silently skipped by deliverToUserChannels().
  slackWebhookUrl    String?   // Slack incoming webhook URL
  telegramBotToken   String?   // From @BotFather
  telegramChatId     String?   // Chat/group/channel ID
  discordWebhookUrl  String?   // Discord webhook URL
  webhookUrl         String?   // Generic HTTP POST endpoint

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// BILLING — Stripe subscription management
// ============================================================================

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ============================================================================
// PROVIDER CONNECTIONS — Connected AI provider accounts
// ============================================================================

model ProviderConnection {
  id              String         @id @default(cuid())
  userId          String
  provider        AIProvider
  displayName     String?
  // Encrypted API key or OAuth token reference (NEVER store raw keys)
  encryptedApiKey String?        @db.Text
  oauthTokenRef   String?
  isActive        Boolean        @default(true)
  lastSyncAt      DateTime?
  lastSyncStatus  SyncStatus     @default(PENDING)
  syncError       String?
  metadata        Json?          // Provider-specific config
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  spendSnapshots SpendSnapshot[]
  usageRecords   UsageRecord[]

  @@unique([userId, provider])
  @@map("provider_connections")
}

// ============================================================================
// SPEND & USAGE TRACKING
// ============================================================================

model SpendSnapshot {
  id                   String   @id @default(cuid())
  userId               String
  providerConnectionId String
  period               String   // "2026-02", "2026-02-17"
  periodType           PeriodType @default(DAILY)
  totalSpend           Decimal  @db.Decimal(12, 4)
  tokenCount           BigInt?
  requestCount         Int?
  modelBreakdown       Json?    // { "claude-4-sonnet": { spend: 12.50, tokens: 50000 } }
  budgetLimit          Decimal? @db.Decimal(12, 2)
  budgetUsedPercent    Decimal? @db.Decimal(5, 2)
  currency             String   @default("USD")
  createdAt            DateTime @default(now())

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerConnection ProviderConnection @relation(fields: [providerConnectionId], references: [id], onDelete: Cascade)

  @@index([userId, period])
  @@index([providerConnectionId, period])
  @@map("spend_snapshots")
}

model UsageRecord {
  id                   String   @id @default(cuid())
  providerConnectionId String
  model                String
  inputTokens          Int
  outputTokens         Int
  totalTokens          Int
  costUsd              Decimal  @db.Decimal(10, 6)
  latencyMs            Int?
  requestType          String?  // "chat", "completion", "embedding", "image"
  metadata             Json?
  timestamp            DateTime @default(now())

  providerConnection ProviderConnection @relation(fields: [providerConnectionId], references: [id], onDelete: Cascade)

  @@index([providerConnectionId, timestamp])
  @@index([model, timestamp])
  @@map("usage_records")
}

// ============================================================================
// ALERTS & BUDGETS
// ============================================================================

model Alert {
  id          String      @id @default(cuid())
  userId      String
  type        AlertType
  provider    AIProvider?
  threshold   Decimal     @db.Decimal(12, 2)
  currentValue Decimal?   @db.Decimal(12, 2)
  message     String?
  channel     AlertChannel @default(EMAIL)
  isActive    Boolean     @default(true)
  triggeredAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

// ============================================================================
// AFFILIATE & MARKETPLACE
// ============================================================================

model AffiliateClick {
  id          String    @id @default(cuid())
  userId      String?
  provider    String
  campaignId  String?
  partnerId   String?   // Integration partner who drove this click
  source      String?   // "marketplace", "topup_banner", "smart_router", "recommendation", "dashboard"
  destination String    // URL clicked
  converted   Boolean   @default(false)
  convertedAt DateTime? // When user actually connected this provider
  commission  Decimal?  @db.Decimal(10, 2)
  createdAt   DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([provider, createdAt])
  @@map("affiliate_clicks")
}

model MarketplaceListing {
  id              String   @id @default(cuid())
  provider        String
  name            String
  description     String?  @db.Text
  category        String   // "cloud_api", "gpu_cloud", "hardware", "on_prem_tools"
  affiliateUrl    String?
  commissionRate  Decimal? @db.Decimal(5, 2) // percentage
  commissionType  String?  // "signup", "recurring", "one_time"
  logoUrl         String?
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  featuredFee     Decimal? @db.Decimal(10, 2)
  sortOrder       Int      @default(0)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("marketplace_listings")
}

// ============================================================================
// TEAMS & GOVERNANCE
// ============================================================================

model Team {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  members   TeamMember[]

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("team_members")
}

// ============================================================================
// API KEYS — For proxy/router access
// ============================================================================

model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  name        String
  keyHash     String   @unique // SHA-256 hash, never store raw
  keyPrefix   String   // First 8 chars for identification: "cg_live_abc12345..."
  permissions Json?    // { "proxy": true, "read_spend": true }
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@map("api_keys")
}

// ============================================================================
// PROXY ROUTING — Smart router decisions and logs
// ============================================================================

model ProxyRequest {
  id              String   @id @default(cuid())
  apiKeyId        String?
  requestModel    String   // requested model class
  routedProvider  String   // where we actually sent it
  routedModel     String   // actual model used
  routingReason   String?  // "cheapest", "fastest", "quality", "compliance"
  inputTokens     Int
  outputTokens    Int
  costUsd           Decimal  @db.Decimal(10, 6)
  savingsUsd        Decimal? @db.Decimal(10, 6) // vs. if they'd used default provider
  prefillCost       Decimal? @db.Decimal(10, 6) // compute-phase cost (input tokens)
  decodeCost        Decimal? @db.Decimal(10, 6) // memory-phase cost (output tokens)
  kvCacheCost       Decimal? @db.Decimal(10, 6) // context retention cost
  memoryTechnology  String?                     // HBM3E, HBM3, HBM2E, GDDR6X, etc.
  costBreakdown     Json?                       // full PhaseAwareCostResult
  latencyMs         Int
  statusCode        Int
  timestamp         DateTime @default(now())

  // Optional link to fleet session if this request came from a managed agent
  fleetSessionId   String?
  fleetSession     FleetSession? @relation(fields: [fleetSessionId], references: [id], onDelete: SetNull)

  @@index([apiKeyId, timestamp])
  @@index([routedProvider, timestamp])
  @@index([fleetSessionId])
  @@map("proxy_requests")
}

// ============================================================================
// FLEET SESSIONS — Multi-agent coordination tracking for managed agents
// ============================================================================
// Tracks sessions from Anthropic Managed Agents, Claude Agent SDK, and custom
// agent runtimes. Aggregates token costs + session runtime + web search costs
// into a unified total-cost-of-ownership view.

model Fleet {
  id          String   @id @default(cuid())
  userId      String
  name        String                          // e.g., "Customer Support", "Research"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Budget guardrails (optional)
  monthlyBudgetUsd Decimal? @db.Decimal(10, 2)
  alertThreshold   Float?   // 0.0–1.0, e.g. 0.8 = alert at 80%

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions FleetSession[]

  @@index([userId])
  @@map("fleets")
}

model FleetSession {
  id             String   @id @default(cuid())
  fleetId        String?  // nullable — sessions can be standalone
  userId         String

  // Identification
  externalId     String?  // upstream session ID (e.g., Anthropic session_id)
  runtime        FleetRuntime                       // which runtime hosts this session
  agentName      String?                            // human-readable agent name
  agentVersion   String?                            // agent definition version
  model          String?                            // primary model for the session
  title          String?                            // user-supplied task title

  // Lifecycle
  startedAt      DateTime @default(now())
  endedAt        DateTime?
  status         FleetSessionStatus @default(RUNNING)

  // Active runtime tracking (for $0.08/hr managed agent billing)
  activeRuntimeMs Int      @default(0)              // accumulated active compute in ms
  idleRuntimeMs   Int      @default(0)              // accumulated idle time in ms

  // Aggregated costs — updated as events arrive
  tokenCostUsd    Decimal  @default(0) @db.Decimal(10, 6)
  runtimeCostUsd  Decimal  @default(0) @db.Decimal(10, 6)  // active_hours * $0.08
  webSearchCount  Int      @default(0)
  webSearchCostUsd Decimal @default(0) @db.Decimal(10, 6)  // searches/1000 * $10
  toolCallCount   Int      @default(0)
  messageCount    Int      @default(0)
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  cachedTokens    Int      @default(0)

  // Metadata
  metadata        Json?                              // arbitrary per-runtime extras

  fleet           Fleet?         @relation(fields: [fleetId], references: [id], onDelete: SetNull)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events          FleetEvent[]
  proxyRequests   ProxyRequest[]

  @@index([userId, startedAt])
  @@index([fleetId, startedAt])
  @@index([status, startedAt])
  @@index([externalId])
  @@map("fleet_sessions")
}

model FleetEvent {
  id             String   @id @default(cuid())
  sessionId      String
  timestamp      DateTime @default(now())
  type           FleetEventType
  payload        Json                               // event-specific data
  tokenDelta     Int?                               // tokens consumed by this event
  costDeltaUsd   Decimal? @db.Decimal(10, 6)        // cost delta from this event

  session        FleetSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@index([type, timestamp])
  @@map("fleet_events")
}

enum FleetRuntime {
  ANTHROPIC_MANAGED           // Anthropic's managed agent runtime
  CLAUDE_AGENT_SDK            // Claude Agent SDK (local/self-hosted)
  CLAUDE_CODE                 // Claude Code CLI / VS Code extension
  GOOSE                       // Block's Goose agent
  SWARMCLAW                   // SwarmClaw agent orchestrator
  CUSTOM                      // User-reported via API
}

enum FleetSessionStatus {
  RUNNING
  IDLE
  COMPLETED
  FAILED
  CANCELLED
}

enum FleetEventType {
  SESSION_START
  SESSION_END
  STATUS_ACTIVE              // agent started actively computing (billing clock on)
  STATUS_IDLE                // agent waiting for input (billing clock off)
  AGENT_MESSAGE              // message from agent
  USER_MESSAGE               // message from user
  TOOL_USE                   // agent called a tool
  TOOL_RESULT                // tool returned result
  WEB_SEARCH                 // $10 per 1000
  MODEL_CALL                 // any model API call, carries token_delta
  ERROR
  CUSTOM
}

// ============================================================================
// ON-PREM GPU CLUSTERS
// ============================================================================

model GpuCluster {
  id              String   @id @default(cuid())
  userId          String
  name            String
  agentToken      String   @unique // Token for the Docker agent to authenticate
  gpuCount        Int
  gpuModel        String?  // "A100", "H100", "4090"
  totalVramGb     Int?
  electricityCostPerKwh Decimal? @db.Decimal(6, 4)
  hardwareCostUsd Decimal? @db.Decimal(12, 2) // For amortization calc
  amortizationMonths Int?  @default(36)
  location        String?
  isOnline        Boolean  @default(false)
  lastHeartbeat   DateTime?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  metrics GpuMetric[]

  @@index([userId])
  @@map("gpu_clusters")
}

model GpuMetric {
  id              String   @id @default(cuid())
  clusterId       String
  gpuIndex        Int
  utilization     Decimal  @db.Decimal(5, 2) // 0-100%
  memoryUsedGb    Decimal? @db.Decimal(8, 2)
  memoryTotalGb   Decimal? @db.Decimal(8, 2)
  powerDrawWatts  Decimal? @db.Decimal(8, 2)
  temperatureC    Decimal? @db.Decimal(5, 1)
  inferenceCount  Int?
  costPerToken    Decimal? @db.Decimal(12, 8) // Calculated TCO per token
  timestamp       DateTime @default(now())

  cluster GpuCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@index([clusterId, timestamp])
  @@map("gpu_metrics")
}

// ============================================================================
// ADMIN — Audit log
// ============================================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ============================================================================
// WAITLIST — Pre-launch email capture
// ============================================================================

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?  // "landing_page", "product_hunt", etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("waitlist_entries")
}

// ============================================================================
// PARTNERS — Integration partners (OpenClaw, LiteLLM, Portkey, etc.)
// ============================================================================

model Partner {
  id              String   @id @default(cuid())
  name            String   @unique
  slug            String   @unique
  callbackKeyHash String   @unique // bcrypt hash of the partner's callback API key
  revSharePct     Float    @default(0.10) // 10% default revenue share
  contactEmail    String
  isActive        Boolean  @default(true)
  metadata        Json?    // Partner-specific config
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  referredUsers User[] @relation("PartnerReferrals")

  @@map("partners")
}

// ============================================================================
// PROVIDER RECOMMENDATIONS — Cost optimization suggestions
// ============================================================================

model ProviderRecommendation {
  id             String     @id @default(cuid())
  userId         String
  fromProvider   AIProvider
  toProvider     AIProvider
  taskType       String     // "code_generation", "chat", "summarization", etc.
  monthlySavings Decimal    @db.Decimal(10, 2)
  savingsPercent Decimal    @db.Decimal(5, 2)
  dismissed      Boolean    @default(false)
  clickedAt      DateTime?
  createdAt      DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dismissed])
  @@map("provider_recommendations")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum SubscriptionTier {
  FREE
  PRO
  HYBRID
  TEAM
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

enum AIProvider {
  ANTHROPIC
  OPENAI
  GOOGLE
  AWS_BEDROCK
  AZURE_OPENAI
  TOGETHER
  GROQ
  MISTRAL
  COHERE
  REPLICATE
  DEEPSEEK
  XAI
  PERPLEXITY
  CEREBRAS
  SAMBANOVA
  FIREWORKS
  MODAL
  LAMBDA
  COREWEAVE
  ON_PREM
  OLLAMA
  // Decentralized AI compute providers
  BITTENSOR
  AKASH
  HYPERBOLIC
}

enum SyncStatus {
  PENDING
  SYNCING
  SUCCESS
  ERROR
}

enum PeriodType {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

enum AlertType {
  BUDGET_WARNING    // 80% of budget
  BUDGET_EXCEEDED   // 100%+ of budget
  SPEND_SPIKE       // Unusual spend increase
  PROVIDER_DOWN     // Provider health check failed
  RATE_LIMIT        // Approaching rate limits
  COST_ANOMALY      // ML-detected anomaly
}

enum AlertChannel {
  EMAIL
  SLACK
  TELEGRAM
  DISCORD
  WEBHOOK
  IN_APP
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ============================================================================
// CREDIT TRADING — Prepaid compute marketplace
// ============================================================================

model CreditBalance {
  id              String   @id @default(cuid())
  userId          String   @unique
  // Decimal(16, 8) gives $0.00000001 resolution (sub-cent precision).
  // The old Decimal(12, 2) silently rounded per-request debits below
  // $0.01 to zero — a 7-output-token Haiku call costs ~$0.000035 and
  // was being recorded as $0.00. Integer part is still 8 digits
  // ($99,999,999 max), which covers every enterprise account we'll
  // realistically have. CreditConsumption.amountConsumed already uses
  // Decimal(12, 6) so this brings CreditBalance into alignment.
  totalAllocated  Decimal  @db.Decimal(16, 8) @default(0)
  available       Decimal  @db.Decimal(16, 8) @default(0)
  delegatedToPool Decimal  @db.Decimal(16, 8) @default(0)
  listedOnMarket  Decimal  @db.Decimal(16, 8) @default(0)
  earned          Decimal  @db.Decimal(16, 8) @default(0)
  autoDelegate    Boolean  @default(false)
  autoDelegatePct Int      @default(50) // percentage to auto-delegate (10-100)
  periodStart     DateTime @default(now())
  periodEnd       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_balances")
}

model CreditTransaction {
  id             String       @id @default(cuid())
  userId         String
  type           CreditTxType
  // Matches CreditBalance precision. Sub-cent consume transactions
  // (cheap-model inference) were being logged as $0.00 under the old
  // Decimal(12, 2) and producing phantom no-op rows.
  amount         Decimal      @db.Decimal(16, 8)
  balanceBefore  Decimal      @db.Decimal(16, 8)
  balanceAfter   Decimal      @db.Decimal(16, 8)
  counterpartyId String?
  offerId        String?
  poolCycleId    String?
  description    String?
  createdAt      DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type])
  @@map("credit_transactions")
}

model CreditOffer {
  id           String      @id @default(cuid())
  sellerId     String
  amount       Decimal     @db.Decimal(12, 2)
  pricePerUnit Decimal     @db.Decimal(8, 4)  // dynamic bounds based on time decay
  totalPrice   Decimal     @db.Decimal(12, 2)
  minPurchase  Decimal?    @db.Decimal(12, 2)
  autoReprice  Boolean     @default(false)    // opt-in: auto-reduce price as credits decay
  repriceFloor Decimal?    @db.Decimal(8, 4)  // seller's minimum acceptable auto-reprice (null = no floor)
  status       OfferStatus @default(ACTIVE)
  filledAmount Decimal     @db.Decimal(12, 2) @default(0)
  buyerId      String?
  expiresAt    DateTime
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  seller User @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([sellerId])
  @@map("credit_offers")
}

model PoolCycle {
  id             String          @id @default(cuid())
  periodStart    DateTime
  periodEnd      DateTime
  totalDelegated Decimal         @db.Decimal(14, 2) @default(0)
  totalConsumed  Decimal         @db.Decimal(14, 2) @default(0)
  revenueRate    Decimal         @db.Decimal(8, 4)  @default(0)
  status         PoolCycleStatus @default(ACTIVE)
  settledAt      DateTime?
  createdAt      DateTime        @default(now())

  delegations PoolDelegation[]

  @@index([status])
  @@map("pool_cycles")
}

model PoolDelegation {
  id           String   @id @default(cuid())
  userId       String
  poolCycleId  String
  amount       Decimal  @db.Decimal(12, 2)
  earnedAmount Decimal  @db.Decimal(12, 2) @default(0)
  createdAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  poolCycle PoolCycle @relation(fields: [poolCycleId], references: [id], onDelete: Cascade)

  @@unique([userId, poolCycleId])
  @@index([poolCycleId])
  @@map("pool_delegations")
}

enum CreditTxType {
  ALLOCATION
  POOL_DELEGATE
  POOL_RECALL
  POOL_EARNING
