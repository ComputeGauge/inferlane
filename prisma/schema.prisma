// ============================================================================
// STREAM W — MEMORY & DECODE INTELLIGENCE LAYER
// ============================================================================

// --- Memory-aware extensions to NodeOperator (W1) ---
// Fields added directly to NodeOperator model above via migration.
// The following model captures periodic memory benchmarks from nodes.

model NodeMemoryProfile {
  id                    String              @id @default(cuid())
  nodeOperatorId        String              @unique
  // Hardware specs
  memoryTechnology      MemoryTechnology    @default(UNKNOWN)
  vramCapacityGB        Int                 @default(0)
  memoryBandwidthGBs    Int                 @default(0)           // GB/s measured
  interconnectType      InterconnectType    @default(ETHERNET)
  // Measured performance
  decodeThroughputTps   Decimal             @default(0) @db.Decimal(10, 2)   // tokens/sec decode
  prefillThroughputTps  Decimal             @default(0) @db.Decimal(10, 2)   // tokens/sec prefill
  maxKvCacheTokens      Int                 @default(0)           // max context under load
  kvCacheGBUsed         Decimal             @default(0) @db.Decimal(8, 2)    // current KV usage
  kvCacheGBAvailable    Decimal             @default(0) @db.Decimal(8, 2)    // free KV capacity
  // Decode specialisation
  nodeRole              NodeRole            @default(HYBRID)
  // P2P KV cache sharing (W4)
  kvSharingEnabled      Boolean             @default(false)
  kvShareBandwidthGBs   Int                 @default(0)           // available P2P bandwidth
  // Benchmarked at
  lastBenchmarkAt       DateTime?
  benchmarkModelId      String?                                    // model used for benchmark
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  nodeOperator          NodeOperator        @relation(fields: [nodeOperatorId], references: [id], onDelete: Cascade)

  @@map("node_memory_profiles")
}

// --- KV Cache Registry (W4) ---

model KvCacheEntry {
  id                String          @id @default(cuid())
  nodeOperatorId    String
  modelId           String                          // which model's KV cache
  promptHash        String                          // SHA-256 of the prompt/context
  tokenRangeStart   Int             @default(0)
  tokenRangeEnd     Int                             // last token cached
  cacheSizeGB       Decimal         @db.Decimal(8, 4)
  status            KvCacheStatus   @default(WARM)
  // Pricing
  pricePerGBHour    Decimal         @default(0.01) @db.Decimal(8, 4)  // $/GB/hour
  totalEarnedUsd    Decimal         @default(0) @db.Decimal(10, 4)
  // Lifecycle
  lastAccessedAt    DateTime        @default(now())
  expiresAt         DateTime                        // auto-evict after this
  createdAt         DateTime        @default(now())

  nodeOperator      NodeOperator    @relation(fields: [nodeOperatorId], references: [id], onDelete: Cascade)

  @@unique([nodeOperatorId, modelId, promptHash])
  @@index([modelId, promptHash, status])
  @@index([nodeOperatorId, status])
  @@index([expiresAt])
  @@map("kv_cache_entries")
}

model KvCacheTransfer {
  id                String          @id @default(cuid())
  sourceNodeId      String                          // node serving the cache
  targetNodeId      String                          // node receiving the cache
  cacheEntryId      String
  transferSizeGB    Decimal         @db.Decimal(8, 4)
  transferTimeMs    Int                             // measured P2P transfer time
  costUsd           Decimal         @db.Decimal(10, 6)
  platformFeeUsd    Decimal         @db.Decimal(10, 6)  // 15% take
  status            KvTransferStatus @default(PENDING)
  createdAt         DateTime        @default(now())
  completedAt       DateTime?

  @@index([sourceNodeId, createdAt])
  @@index([targetNodeId, createdAt])
  @@index([status])
  @@map("kv_cache_transfers")
}

// --- Enums (W1) ---

enum MemoryTechnology {
  HBM3E
  HBM3
  HBM2E
  GDDR6X
  GDDR6
  DDR5
  UNKNOWN
}

enum InterconnectType {
  NVLINK
  PCIE5
  PCIE4
  INFINIBAND
  ETHERNET
}

enum NodeRole {
  PREFILL_OPTIMISED     // High compute, moderate memory — good for prompt processing
  DECODE_OPTIMISED      // High memory bandwidth — good for token generation
  HYBRID                // Balanced — handles both phases
  KV_CACHE_SERVER       // Primarily serves cached KV data to other nodes
}

enum KvCacheStatus {
  WARM        // Actively in GPU memory, instant access
  COLD        // Swapped to flash/SSD, needs reload (50-200ms)
  EVICTING    // Being removed, no new access
  EXPIRED     // Past TTL, awaiting cleanup
}

enum KvTransferStatus {
  PENDING
  TRANSFERRING
  COMPLETED
  FAILED
}

