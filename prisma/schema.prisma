model TradingApiKey {
  id              String    @id @default(cuid())
  userId          String
  name            String                          // "My Trading Bot", "Prediction Market"
  keyHash         String    @unique               // SHA-256 of ilt_ prefixed key
  permissions     String[]                        // ['read', 'trade', 'settle']
  rateLimit       Int       @default(100)         // req/min
  isActive        Boolean   @default(true)
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("trading_api_keys")
}

model ComputeOrder {
  id                String          @id @default(cuid())
  userId            String
  side              OrderSide
  orderType         OrderType
  status            OrderStatus     @default(OPEN)
  // What compute is being traded
  qualityTier       ComputeQualityTier
  inferenceType     ComputeInferenceType?
  latencyClass      ComputeLatencyClass?
  // Pricing
  quantity          Decimal         @db.Decimal(14, 6)    // Credits
  pricePerUnit      Decimal         @db.Decimal(8, 4)     // $/credit
  filledQuantity    Decimal         @default(0) @db.Decimal(14, 6)
  avgFillPrice      Decimal?        @db.Decimal(8, 4)
  // Expiry
  expiresAt         DateTime
  // Linkage
  tradingApiKeyId   String?                               // null = placed via dashboard
  classificationId  String?                               // Optional: specific classification
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  fills             OrderFill[]

  @@index([status, qualityTier, side])
  @@index([userId, status])
  @@index([expiresAt])
  @@map("compute_orders")
}

model OrderFill {
  id              String        @id @default(cuid())
  buyOrderId      String
  sellOrderId     String
  quantity        Decimal       @db.Decimal(14, 6)
  pricePerUnit    Decimal       @db.Decimal(8, 4)
  totalUsd        Decimal       @db.Decimal(14, 6)
  platformFeeUsd  Decimal       @db.Decimal(10, 4)        // 2.5% take rate
  createdAt       DateTime      @default(now())

  buyOrder        ComputeOrder  @relation(fields: [buyOrderId], references: [id])

  @@index([buyOrderId])
  @@index([sellOrderId])
  @@index([createdAt])
  @@map("order_fills")
}

model ComputeFuture {
  id                String          @id @default(cuid())
  creatorId         String
  contractType      FutureType
  status            FutureStatus    @default(OPEN)
  // Contract spec
  qualityTier       ComputeQualityTier
  inferenceType     ComputeInferenceType?
  quantity          Decimal         @db.Decimal(14, 6)     // Credits
  strikePrice       Decimal         @db.Decimal(8, 4)      // $/credit at delivery
  deliveryDate      DateTime
  // Settlement
  settlementPrice   Decimal?        @db.Decimal(8, 4)      // Actual price at delivery
  pnlUsd            Decimal?        @db.Decimal(14, 6)
  marginRequired    Decimal         @db.Decimal(14, 6)     // Escrow held
  // Counterparty
  counterpartyId    String?
  createdAt         DateTime        @default(now())
  settledAt         DateTime?

  creator           User            @relation("FutureCreator", fields: [creatorId], references: [id])

  @@index([status, deliveryDate])
  @@index([creatorId, status])
  @@map("compute_futures")
}

model ComputeIndex {
  id              String    @id @default(cuid())
  name            String    @unique                        // "IL-FRONTIER", "IL-ECONOMY"
  description     String
  qualityTier     ComputeQualityTier
  currentValue    Decimal   @db.Decimal(8, 4)              // Current $/credit
  change24h       Decimal   @default(0) @db.Decimal(8, 4)
  changePct24h    Decimal   @default(0) @db.Decimal(8, 4)
  volume24hUsd    Decimal   @default(0) @db.Decimal(14, 2)
  high24h         Decimal   @default(0) @db.Decimal(8, 4)
  low24h          Decimal   @default(0) @db.Decimal(8, 4)
  dataPoints      Int       @default(0)
  updatedAt       DateTime  @updatedAt

  snapshots       IndexSnapshot[]

  @@map("compute_indices")
}

model IndexSnapshot {
  id              String        @id @default(cuid())
  indexId         String
  value           Decimal       @db.Decimal(8, 4)
  volumeUsd       Decimal       @db.Decimal(14, 2)
  snapshotAt      DateTime      @default(now())

  index           ComputeIndex  @relation(fields: [indexId], references: [id], onDelete: Cascade)

  @@index([indexId, snapshotAt])
  @@map("index_snapshots")
}

// --- Subscription tiers for supply side (node operators) ---

model SupplierSubscription {
  id                   String                @id @default(cuid())
  nodeOperatorId       String                @unique
  tier                 SupplierTier          @default(STARTER)
  stripeSubscriptionId String?               @unique
  status               SubscriptionStatus    @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  nodeOperator         NodeOperator          @relation(fields: [nodeOperatorId], references: [id], onDelete: Cascade)

  @@map("supplier_subscriptions")
}

enum SupplierTier {
  STARTER           // Free — 100 req/day, weekly payouts, DEFERRED lane
  PROFESSIONAL      // $29/mo — 10K req/day, daily payouts, STANDARD eligible
  ENTERPRISE        // $99/mo — unlimited, instant payouts, INSTANT eligible, priority routing
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  LIMIT
  MARKET
}

enum OrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  EXPIRED
}

enum FutureType {
  FORWARD            // Binding delivery contract
  OPTION_CALL        // Right to buy at strike
  OPTION_PUT         // Right to sell at strike
  // Stream W: Memory & Decode futures
  DECODE_FORWARD     // Forward contract on decode throughput (tokens/sec)
  MEMORY_FORWARD     // Forward contract on memory bandwidth (GB/s)
  DECODE_OPTION_CALL // Right to buy decode capacity at strike
  MEMORY_OPTION_PUT  // Right to sell memory bandwidth at strike
}

enum FutureStatus {
  OPEN
