  userId          String
  proxyRequestId  String?          // links to ProxyRequest
  sourceType      CreditSourceType
  sourceId        String?          // offerId, poolCycleId, or creditBalanceId
  amountConsumed  Decimal          @db.Decimal(12, 6)
