// ============================================================================
// STREAM T — MICROPAYMENT SETTLEMENT FOR DECENTRALISED NODE OPERATORS
// ============================================================================

model NodeOperator {
  id                String    @id @default(cuid())
  userId            String    @unique
  displayName       String?
  stripeAccountId   String?   @unique            // Stripe Connect Express account
  payoutEnabled     Boolean   @default(false)     // Set true after Stripe onboarding
  pendingBalance    Decimal   @default(0) @db.Decimal(14, 6)   // Unsettled earnings
  lifetimeEarned    Decimal   @default(0) @db.Decimal(14, 6)
  capabilities      Json      @default("{}")      // Model support, hardware specs
  regions           String[]                      // ISO 3166-1 alpha-2
  privacyTier       RoutingPrivacyTier @default(TRANSPORT_ONLY)
  teeAttested       Boolean   @default(false)
  reputationScore   Int       @default(50)        // 0–100, starts at 50
  totalRequests     Int       @default(0)
  failedRequests    Int       @default(0)
  avgLatencyMs      Int       @default(0)
  isOnline          Boolean   @default(false)
  lastSeenAt        DateTime?
  apiEndpoint       String?                       // Node's inference endpoint
  maxConcurrent     Int       @default(4)         // Max simultaneous requests
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  referredByNodeId  String?                       // Node that referred this operator
  referredBy        NodeOperator?  @relation("NodeReferrals", fields: [referredByNodeId], references: [id], onDelete: SetNull)
  referrals         NodeOperator[] @relation("NodeReferrals")

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      NodeTransaction[]
  payouts           NodePayout[]
  memoryProfile     NodeMemoryProfile?
  kvCacheEntries    KvCacheEntry[]
  supplierSubscription SupplierSubscription?

  @@index([isOnline, reputationScore])
  @@index([regions])
  @@index([referredByNodeId])
  @@map("node_operators")
}

model NodeTransaction {
  id              String        @id @default(cuid())
  nodeOperatorId  String
  type            NodeTxType
  amount          Decimal       @db.Decimal(14, 6)
  balanceBefore   Decimal       @db.Decimal(14, 6)
  balanceAfter    Decimal       @db.Decimal(14, 6)
  requestId       String?                          // ProxyRequest linkage
  payoutId        String?                          // NodePayout linkage
  description     String?
  createdAt       DateTime      @default(now())

  nodeOperator    NodeOperator  @relation(fields: [nodeOperatorId], references: [id], onDelete: Cascade)

  @@index([nodeOperatorId, createdAt])
  @@index([type])
  @@map("node_transactions")
}

model NodePayout {
  id              String        @id @default(cuid())
  nodeOperatorId  String
  amount          Decimal       @db.Decimal(14, 6)
  stripeTransferId String?
  status          PayoutStatus  @default(PENDING)
  periodStart     DateTime
  periodEnd       DateTime
  requestCount    Int           @default(0)
  createdAt       DateTime      @default(now())
  processedAt     DateTime?

  nodeOperator    NodeOperator  @relation(fields: [nodeOperatorId], references: [id], onDelete: Cascade)

  @@index([nodeOperatorId, status])
  @@index([status, createdAt])
  @@map("node_payouts")
}

enum NodeTxType {
  NODE_EARNING
  NODE_PENALTY
  NODE_PAYOUT
  NODE_BONUS
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================================================
// STREAM V — COMPUTE TRADING PROTOCOL (DECENTRALISED EXCHANGE LAYER)
