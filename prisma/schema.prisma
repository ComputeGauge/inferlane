  lastUsedAt    DateTime?
  useCount      Int      @default(0)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@map("prompt_templates")
}

// ============================================================================
// COMMERCIAL BUILD — Phase 2/4/5: KYC, Attestation, Ledger, Disputes
// ============================================================================
//
// These tables form the authoritative money + trust layer for the
// marketplace. See commercial/BUILD_TRACKER.md for status and
// commercial/DECISIONS.md for locked design choices.
//
// Invariants:
//   - ledger_entries are append-only. Never UPDATE or DELETE a row.
//   - Every settlement emits exactly one WORKLOAD_COMPLETE ledger entry.
//   - Every dispute with refund > 0 emits exactly one DISPUTE_RESOLVE_*
//     ledger entry that balances to zero.
//   - AttestationRecord.measurement is the canonical identity for a
//     given TEE execution and feeds into dispute evidence.

model KycSession {
  id                 String        @id @default(cuid())
  subjectUserId      String                                   // FK to User (no cascade — we retain on account delete)
  purpose            KycPurpose
  provider           KycProvider   @default(STRIPE_IDENTITY)
  providerSessionId  String        @unique                    // e.g. Stripe vs_xxx
  status             KycStatus     @default(NOT_STARTED)
  attestationHash    String?                                  // SHA-256 of (session id + status + report id)
  verifiedAt         DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?
  expiresAt          DateTime
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  subject            User          @relation("UserKycSessions", fields: [subjectUserId], references: [id])

  @@index([subjectUserId, status])
  @@index([status, createdAt])
  @@index([providerSessionId])
  @@map("kyc_sessions")
}

enum KycPurpose {
  BUYER_HIGH_VALUE
  SELLER_ONBOARDING
}

enum KycProvider {
  STRIPE_IDENTITY
  MANUAL_REVIEW
}

enum KycStatus {
  NOT_STARTED
  IN_PROGRESS
  REQUIRES_ACTION
  VERIFIED
  REJECTED
  EXPIRED
}

model AttestationRecord {
  id                 String            @id @default(cuid())
  nodeOperatorId     String?                                  // null if attestation is for a buyer node
  settlementRecordId String?                                  // null if this is a pre-flight check
  type               AttestationType
  outcome            AttestationOutcome
  measurement        String?                                  // canonical identity hash
  nonce              String                                   // replay protection
  evidenceHash       String                                   // SHA-256 of the raw evidence blob
  verifier           String?                                  // e.g. "azure-attestation-service"
  summary            String
  validUntil         DateTime?
  collectedAt        DateTime
  verifiedAt         DateTime          @default(now())

  @@index([nodeOperatorId, verifiedAt])
  @@index([outcome, verifiedAt])
  @@index([settlementRecordId])
  @@index([measurement])
  @@map("attestation_records")
}

enum AttestationType {
  AZURE_CONFIDENTIAL_VM
  GCP_CONFIDENTIAL_SPACE
  INTEL_TDX
  AMD_SEV_SNP
  NVIDIA_CC
  APPLE_SILICON_MDM
  MOCK
}

enum AttestationOutcome {
  VERIFIED
  STALE
  BAD_SIGNATURE
  POLICY_VIOLATION
  NONCE_MISMATCH
  UNSUPPORTED
  ERROR
}

// ----------------------------------------------------------------------------
// Double-entry ledger
// ----------------------------------------------------------------------------
// Every money event produces one LedgerEntry with N LedgerLegs. The sum of
// DEBIT legs must equal the sum of CREDIT legs for each entry (enforced in
// application code and verified nightly by a reconciliation job).
//
// amounts are stored as Int USD cents. We use Int (not BigInt) because a
// single workload will never exceed ~$20M and Postgres INT tops out at $21M.
// If we ever cross that threshold, we migrate to BigInt with a one-way
// script.

model LedgerEntry {
  id                  String            @id @default(cuid())
  eventType           LedgerEventType
  groupId             String                                  // correlates related entries (e.g. all legs of one workload)
  settlementRecordId  String?                                 // FK to ComputeSettlementRecord
  disputeCaseId       String?                                 // FK to DisputeCase
  memo                String?
  approvedByUserId    String?                                 // for ADJUSTMENT events
  createdAt           DateTime          @default(now())

  legs                LedgerLeg[]

  @@index([eventType, createdAt])
  @@index([groupId])
  @@index([settlementRecordId])
  @@index([disputeCaseId])
  @@map("ledger_entries")
}

model LedgerLeg {
  id                  String            @id @default(cuid())
  entryId             String
  account             LedgerAccount
  direction           LedgerDirection
  amountUsdCents      BigInt                                   // BigInt to match application code
  subjectUserId       String?
  subjectOperatorId   String?
  createdAt           DateTime          @default(now())

  entry               LedgerEntry       @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@index([account, createdAt])
  @@index([subjectUserId])
  @@index([subjectOperatorId])
  @@map("ledger_legs")
}

enum LedgerAccount {
  BUYER_WALLET
  ESCROW_HELD
  PLATFORM_FEE
  RESERVE_FUND
  OPERATOR_PENDING
  OPERATOR_PAID_OUT
  DISPUTE_REFUND
  OPERATIONAL_CASH
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum LedgerEventType {
  BUYER_DEPOSIT
  WORKLOAD_COMMIT
  WORKLOAD_COMPLETE
  DISPUTE_OPEN
  DISPUTE_RESOLVE_BUYER
  DISPUTE_RESOLVE_OPERATOR
  OPERATOR_PAYOUT
  RESERVE_DRAWDOWN
  ADJUSTMENT
}

// ----------------------------------------------------------------------------
// Disputes
// ----------------------------------------------------------------------------

model DisputeCase {
  id                  String            @id @default(cuid())
  settlementRecordId  String                                  // FK to ComputeSettlementRecord
  buyerUserId         String
  operatorId          String                                  // FK to NodeOperator
  reason              DisputeReason
  description         String                                  // buyer statement
  amountUsdCents      BigInt                                   // amount at stake
  status              DisputeCaseStatus @default(OPEN)
  openedAt            DateTime          @default(now())
  evidenceDeadlineAt  DateTime
  resolvedAt          DateTime?
  decidedByUserId     String?                                  // reviewer
  outcome             DisputeOutcome?
  refundCents         BigInt?
  reasoning           String?
  drawdownFromReserve Boolean           @default(false)

  evidence            DisputeEvidence[]

  @@index([status, openedAt])
  @@index([settlementRecordId])
  @@index([buyerUserId])
  @@index([operatorId])
  @@map("dispute_cases")
}

model DisputeEvidence {
  id               String                @id @default(cuid())
  disputeCaseId    String
  kind             DisputeEvidenceKind
  submittedByUserId String
  submittedAt      DateTime              @default(now())
  contentHash      String                                     // SHA-256 of the blob
  contentUrl       String?                                    // signed URL in object storage

  disputeCase      DisputeCase           @relation(fields: [disputeCaseId], references: [id], onDelete: Cascade)

  @@index([disputeCaseId])
  @@map("dispute_evidence")
}

enum DisputeReason {
  WORK_INCOMPLETE
  QUALITY_FAILURE
  CAPABILITY_MISREP
  ATTESTATION_FAILED
  LATENCY_BREACH
  DATA_HANDLING
  OTHER
}

enum DisputeCaseStatus {
  OPEN
  EVIDENCE_REQUESTED
  UNDER_REVIEW
  RESOLVED_BUYER
  RESOLVED_OPERATOR
  RESOLVED_SPLIT
  CANCELLED
}

enum DisputeOutcome {
  BUYER
  OPERATOR
  SPLIT
}

enum DisputeEvidenceKind {
  BUYER_STATEMENT
  OPERATOR_STATEMENT
  ATTESTATION_LOG
  ROUTER_LOG
  FILE_HASH
}

model DisputeAppeal {
  id                  String             @id @default(cuid())
  disputeCaseId       String
  appellantUserId     String                                   // buyer or operator
  appellantRole       AppealRole
  statement           String
  newEvidenceUrls     String[]                                 // signed URLs to newly submitted evidence
  status              AppealStatus       @default(PENDING)
  panelReviewers      String[]                                 // reviewer user ids assigned
  overturned          Boolean?
  overrideRefundCents BigInt?
  decidedAt           DateTime?
  decidedByUserId     String?
  reasoning           String?
  createdAt           DateTime           @default(now())

  @@index([disputeCaseId])
  @@index([status, createdAt])
  @@index([appellantUserId])
  @@map("dispute_appeals")
}

enum AppealRole {
  BUYER
  OPERATOR
}

enum AppealStatus {
  PENDING
  UNDER_PANEL_REVIEW
  OVERTURNED
  UPHELD
  WITHDRAWN
}

// ============================================================================
// COMMERCIAL BUILD — Phase F1/F2/F4/F6: Float model (Tether-style)
// ============================================================================
// Strategy doc: commercial/FLOAT_MODEL.md
//
// The float model is how InferLane makes money from near-free routing:
//   1. Buyer wallet balances earn Treasury yield.
//   2. Operator pending balances earn yield during the dispute window
//      + payout cycle.
//   3. Reserve fund earns yield + provides dispute liquidity.
//   4. Provider rebates capture the difference between rack rate and
//      privately-negotiated partnership rates.
//
// All money movements still flow through the double-entry ledger
// (ledger_entries + ledger_legs). These tables are projections and
// config — never sources of truth for balances.

model BuyerWallet {
  id                   String        @id @default(cuid())
  userId               String        @unique
  /// Cached balance from the ledger projection — updated on each
  /// ledger write, re-derived nightly for drift detection.
  availableUsdCents    BigInt        @default(0)
  reservedUsdCents     BigInt        @default(0)
  totalDepositedCents  BigInt        @default(0)
  totalSpentCents      BigInt        @default(0)
  preferredCurrency    WalletCurrency @default(USD)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  transactions         WalletTransaction[]

  @@index([userId])
  @@map("buyer_wallets")
}

model WalletTransaction {
  id             String            @id @default(cuid())
  walletId       String
  ledgerEntryId  String?                                 // FK to ledger_entries if applicable
  source         WalletTxSource
  externalId     String                                  // Stripe charge id, Tether tx hash, etc.
  idempotencyKey String            @unique
  amountUsdCents BigInt
  status         WalletTxStatus    @default(PENDING)
  memo           String?
  createdAt      DateTime          @default(now())
  confirmedAt    DateTime?

  wallet         BuyerWallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([source, externalId])
  @@index([status])
  @@map("wallet_transactions")
}

enum WalletCurrency {
  USD
  USDT
}

enum WalletTxSource {
  STRIPE_CARD
  STRIPE_ACH
  TETHER_USDT
  MANUAL_CREDIT
  REFUND
  ADJUSTMENT
}

enum WalletTxStatus {
  PENDING
  CONFIRMED
  FAILED
  REVERSED
}

model TreasuryHolding {
  id                    String             @id @default(cuid())
  vehicle               TreasuryVehicle
  pool                  TreasuryPool
  balanceUsdCents       BigInt             @default(0)
  apyBps                Int                @default(0)
  partnerReference      String?
  lastReconciledAt      DateTime           @default(now())
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@unique([vehicle, pool])
  @@index([pool])
  @@map("treasury_holdings")
}

enum TreasuryVehicle {
  STRIPE_TREASURY
  MODERN_TREASURY
  BROKER_DEALER_SWEEP
  USDT_RESERVE
  OPERATIONAL_CASH
}

enum TreasuryPool {
  BUYER_WALLETS
  OPERATOR_PENDING
  RESERVE_FUND
}

model ProviderRebateConfig {
  id                      String           @id @default(cuid())
  provider                String
  model                   String?
  kind                    RebateKind
  discountBps             Int
  volumeTiers             Json?
  creditPoolCentsPerMonth BigInt?
  offPeakWindows          Json?
  effectiveFrom           DateTime
  effectiveUntil          DateTime?
  disclosed               Boolean          @default(false)
  notes                   String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@unique([provider, model, effectiveFrom])
  @@index([provider])
  @@map("provider_rebate_configs")
}

model ProviderRebateEarning {
  id                 String    @id @default(cuid())
  provider           String
  model              String
  rackRateUsdCents   BigInt
  invoicedUsdCents   BigInt
  rebateUsdCents     BigInt
  proxyRequestId     String?                       // FK to proxy_requests
  appliedAt          DateTime  @default(now())

  @@index([provider, appliedAt])
  @@index([proxyRequestId])
  @@map("provider_rebate_earnings")
}

enum RebateKind {
  FLAT_PERCENT
  VOLUME_TIERED
  CREDIT_POOL
  OFF_PEAK
}

// ===========================================================================
// COMPUTE EXCHANGE — Phase 2
//
// The InferLane Compute Exchange: providers list excess capacity as offers,
// buyers request inference at spot prices, the exchange matches and settles.
// ===========================================================================

enum ExchangeProviderType {
  CENTRALIZED    // Anthropic, OpenAI, Google
  DECENTRALIZED  // Darkbloom, OpenClaw, individual operators
  HYBRID         // Enterprise on-prem with cloud burst
}

enum ExchangeOfferStatus {
  ACTIVE
  PAUSED
  EXHAUSTED     // max concurrent reached
  EXPIRED       // past availableUntil
  WITHDRAWN
}

model CapacityOffer {
  id                  String   @id @default(cuid())
  providerId          String   // NodeOperator ID or provider user ID
  providerType        ExchangeProviderType

  // What's being offered
  model               String   // e.g. "claude-sonnet-4-5", "llama-3.3-70b"
  maxTokensPerSec     Int      // throughput ceiling
  maxConcurrent       Int      @default(10)
  gpuType             String?  // e.g. "H100", "Apple M4 Max", "RTX 4090"
  memoryGb            Int?     // available VRAM / unified memory

  // Pricing (per million tokens)
  inputPricePerMtok   Decimal  @db.Decimal(12, 6)
  outputPricePerMtok  Decimal  @db.Decimal(12, 6)
  minimumSpendUsd     Decimal  @db.Decimal(12, 2) @default(0)

  // Availability window
  availableFrom       DateTime
  availableUntil      DateTime
  timezone            String   @default("UTC")
  recurringCron       String?  // e.g. "0 22 * * *" for nightly 10pm-6am

  // Trust
  attestationType     AttestationType?
  lastAttestationAt   DateTime?
  attestationHash     String?  // SHA-256 of last verified attestation
  attestationRequired Boolean  @default(false) // buyers must use TEE path

  // Status
  status              ExchangeOfferStatus @default(ACTIVE)
  utilizationPct      Int      @default(0) // current load 0-100
  totalFills          Int      @default(0) // lifetime fill count
  totalRevenueUsd     Decimal  @db.Decimal(16, 8) @default(0)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  fills               CapacityFill[]

  @@index([model, status, inputPricePerMtok])
  @@index([availableFrom, availableUntil])
  @@index([providerType, status])
  @@map("capacity_offers")
}

model CapacityFill {
  id                  String   @id @default(cuid())
  offerId             String
  buyerUserId         String
  sellerProviderId    String

  // What was filled
  model               String
  inputTokens         Int
  outputTokens        Int
  latencyMs           Int

  // Economics
  buyerPaidUsd        Decimal  @db.Decimal(16, 8)
  sellerEarnedUsd     Decimal  @db.Decimal(16, 8)
  exchangeFeeUsd      Decimal  @db.Decimal(16, 8)  // InferLane's spread
  spreadBps           Int      // basis points of spread taken

  // Provenance
  attestationHash     String?  // proof the execution was TEE-attested
  proxyRequestId      String?  // link to the original proxy request log

  createdAt           DateTime @default(now())

  // Relations
  offer               CapacityOffer @relation(fields: [offerId], references: [id])

  @@index([buyerUserId, createdAt])
  @@index([sellerProviderId, createdAt])
  @@index([offerId])
  @@map("capacity_fills")
}
