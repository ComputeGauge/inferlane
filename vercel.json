{
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && next build",
  "regions": ["iad1"],
  "crons": [
    { "path": "/api/cron/stale-nodes", "schedule": "0 0 * * *" },
    { "path": "/api/cron/expire-orders", "schedule": "0 1 * * *" },
    { "path": "/api/cron/update-indices", "schedule": "0 2 * * *" },
    { "path": "/api/cron/settle-nodes", "schedule": "0 3 * * *" },
    { "path": "/api/cron/settle-futures", "schedule": "0 4 * * *" },
    { "path": "/api/cron/settle-pool", "schedule": "0 5 * * *" },
    { "path": "/api/cron/allocate-credits", "schedule": "0 6 * * 1" },
    { "path": "/api/cron/reprice-offers", "schedule": "0 7 * * *" },
    { "path": "/api/cron/expire-offers", "schedule": "0 8 * * *" },
    { "path": "/api/cron/digest", "schedule": "0 9 * * 1" },
    { "path": "/api/cron/evict-kv-cache", "schedule": "0 10 * * *" },
    { "path": "/api/cron/scan-promotions", "schedule": "0 11 * * *" },
    { "path": "/api/cron/execute-scheduled", "schedule": "0 12 * * *" },
    { "path": "/api/cron/sync-usage", "schedule": "0 13 * * *" },
    { "path": "/api/cron/process-dispatch", "schedule": "0 14 * * *" },
    { "path": "/api/cron/discover-promotions", "schedule": "0 15 * * *" },
    { "path": "/api/cron/orchestrate-capacity", "schedule": "0 16 * * *" },
    { "path": "/api/cron/reconcile-ledger", "schedule": "10 3 * * *" },
    { "path": "/api/cron/sweep-treasury", "schedule": "15 17 * * *" },
    { "path": "/api/cron/execute-payouts", "schedule": "30 18 * * 1" },
    { "path": "/api/cron/purge-deleted-accounts", "schedule": "45 2 * * *" },
    { "path": "/api/cron/purge-stale-data", "schedule": "30 3 * * *" },
    { "path": "/api/cron/market-make", "schedule": "0 20 * * *" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
