{
  "name": "@inferlane/mcp",
  "version": "0.7.0",
  "description": "Local-first compute fuel gauge for Claude Code + 49 MCP tools for model selection, spend tracking, credibility, routing, and the compute exchange. Auto-ingests real usage from Claude Code transcripts — no API key needed. Works with Claude, Cursor, Windsurf, and any MCP-compatible agent.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "inferlane-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "dashboard.html",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "llm",
    "cost",
    "finops",
    "tracking",
    "model-selection",
    "claude",
    "cursor",
    "openai",
    "anthropic",
    "compute",
    "agent",
    "credibility",
    "local-inference",
    "ollama",
    "vllm"
  ],
  "author": {
    "name": "InferLane",
    "email": "travel_world_intl@proton.me",
    "url": "https://inferlane.dev"
  },
  "homepage": "https://inferlane.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inferlane/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/inferlane/mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "typescript": "^5.7.0"
  }
}
